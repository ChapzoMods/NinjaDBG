# Maintainer: Chapzoo <ChapzoMods@users.noreply.github.com>
# NinjaDBG v1.1.2 - Stealth-Aware Native Debugger
# AUR package: https://aur.archlinux.org/packages/ninjadb

pkgname=ninjadb
pkgver=1.1.2
pkgrel=1
pkgdesc="Stealth-Aware Native Debugger for Linux x86-64 (CLI-only, Apache-2.0)"
arch=('x86_64')
url="https://github.com/ChapzoMods/NinjaDBG"
license=('Apache-2.0')
depends=('gcc-libs')
makedepends=('gcc' 'make' 'pkgconf')
optdepends=(
    'wine: for Windows PE debugging'
    'qemu-user: for macOS Mach-O debugging'
    'python-angr: for decompilation and Python scripting'
    'retdec: for native C decompilation'
    'lua: for Lua scripting'
    'linux-headers: for kernel-level stealth module'
)
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/ChapzoMods/NinjaDBG/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "${srcdir}/NinjaDBG-${pkgver}"
    make -j$(nproc)
    gcc -shared -fPIC -O2 -ldl -o build/libninjastealth.so scripts/ninjastealth.c
}

package() {
    cd "${srcdir}/NinjaDBG-${pkgver}"
    install -Dm755 build/ninjadb "${pkgdir}/usr/bin/ninjadb"
    install -Dm755 build/libninjastealth.so "${pkgdir}/usr/lib/ninjadb/libninjastealth.so"
    install -Dm644 scripts/ninjastealth.c "${pkgdir}/usr/share/ninjadb/ninjastealth.c"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/ninjadb/README.md"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/ninjadb/LICENSE"
    install -Dm644 INSTALL.md "${pkgdir}/usr/share/doc/ninjadb/INSTALL.md"
    install -Dm644 CONTRIBUTING.md "${pkgdir}/usr/share/doc/ninjadb/CONTRIBUTING.md"
    install -d "${pkgdir}/usr/share/bash-completion/completions"
    cat > "${pkgdir}/usr/share/bash-completion/completions/ninjadb" << 'COMPLETION'
_ninjadb_completion() {
    local cur opts
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    opts="attach launch detach kill continue step next finish break tbreak watch delete info x set disas edit decomp pretty bt target patch stealth kernel script help quit"
    if [[ ${COMP_CWORD} -eq 1 ]]; then
        COMPREPLY=( $(compgen -W "${opts}" -- ${cur}) )
    fi
}
complete -F _ninjadb_completion ninjadb
COMPLETION
}
